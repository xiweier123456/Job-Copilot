# Milvus
MILVUS_HOST=localhost
MILVUS_PORT=19530
MILVUS_COLLECTION=job_chunks

# Embedding / Rerank (local model directories)
EMBEDDING_MODEL=your-local-path-to-bge-small-zh-v1.5
RERANKER_MODEL=your-local-path-to-BAAI-bge-reranker-v2-m3

# LLM (OpenAI-compatible API)
# DeepSeek: https://api.deepseek.com/v1        model: deepseek-chat
# Zhipu:    https://open.bigmodel.cn/api/paas/v4  model: glm-4-flash
# Tongyi:   https://dashscope.aliyuncs.com/compatible-mode/v1  model: qwen-plus
SERVICE_LLM_API_KEY=your-llm-api-key-here
SERVICE_LLM_BASE_URL=https://api.deepseek.com/v1
SERVICE_LLM_MODEL=deepseek-chat
HF_TOKEN=your-huggingface-token-here
TAVILY_API_KEY=your-tavily-api-key-here

# Memory (mem0 + Milvus)
MEMORY_ENABLED=true
MEMORY_RECALL_TOP_K=3
MEMORY_RECALL_SCORE_THRESHOLD=
MEMORY_RECENT_HISTORY_LIMIT=4
MEMORY_PROMPT_CHAR_BUDGET=1200
MEM0_COLLECTION_NAME=mem0_chat_memory
MEM0_LLM_PROVIDER=deepseek
MEM0_LLM_MODEL=
MEM0_EMBEDDER_PROVIDER=huggingface
MEM0_EMBEDDER_MODEL=
MEM0_EMBEDDER_DIMS=
MEM0_HISTORY_DB_PATH=outputs/mem0/history.db
CONTEXT_COMPRESSION_ENABLED=true
CONTEXT_COMPRESSION_TRIGGER_TOKENS=6000
CONTEXT_COMPRESSION_TARGET_TOKENS=2500
CONTEXT_COMPRESSION_MAX_INPUT_CHARS=16000
CONTEXT_COMPRESSION_FALLBACK_RECENT_CHARS=6000
CHECKPOINT_BACKEND=sqlite
CHECKPOINT_SQLITE_PATH=outputs/checkpoints/langgraph.db

MCP_HOST=127.0.0.1
MCP_PORT=8000
MCP_PATH=/mcp
MCP_TRANSPORT=streamable-http
MCP_CLIENT_TIMEOUT=30
MCP_DEBUG=false
MCP_TOOL_NAME_PREFIX=false
MCP_EXTERNAL_DISCOVERY_TTL_SECONDS=60
MCP_EXTERNAL_DISCOVERY_FAILURE_TTL_SECONDS=30
LANGSMITH_API_KEY=your-langsmith-api-key-here

# Agent LLM (Minimax)
AGENT_LLM_API_KEY=your-agent-llm-api-key-here
AGENT_LLM_BASE_URL=https://api.minimaxi.com/v1
AGENT_LLM_MODEL=MiniMax-M2.7
